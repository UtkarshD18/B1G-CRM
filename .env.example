# Server Configuration
PORT=3010
SOCKET_PORT=3002
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL=postgres://b1gcrm:b1gcrm_local_dev@127.0.0.1:5432/b1gcrm
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=b1gcrm
PGPASSWORD=b1gcrm_local_dev
PGDATABASE=b1gcrm

# JWT & Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# Payment Gateway Keys
STRIPE_API_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxx

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@b1gcrm.com

# WhatsApp & Meta Integration
META_VERIFY_TOKEN=verify-token-for-webhooks
META_WEBHOOK_TOKEN=webhook-callback-token
WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxx
META_APP_ID=xxxxxxxxxxxx
META_APP_SECRET=xxxxxxxxxxxx

# Redis Configuration (Optional - for caching/sessions)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# AWS S3 Configuration (for media storage)
AWS_ACCESS_KEY=xxxxxxxxxxxx
AWS_SECRET_KEY=xxxxxxxxxxxx
AWS_S3_BUCKET=b1g-crm-media
AWS_REGION=us-east-1
S3_ENABLED=false

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3010/api

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./client/public/media

# Twilio Configuration (optional)
TWILIO_ACCOUNT_SID=xxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_WHATSAPP=true
ENABLE_INSTAGRAM=true
ENABLE_TELEGRAM=true
ENABLE_PAYMENTS=true
ENABLE_BROADCAST=true
ENABLE_CHATBOT=true
ENABLE_API_KEYS=true
