# Server Configuration
PORT=3010
SOCKET_PORT=3002
NODE_ENV=development

# Database Configuration (PostgreSQL)
# For local Node without Docker, use PGHOST=127.0.0.1.
# For Docker Compose, docker-compose.yml overrides PGHOST to the postgres service.
DATABASE_URL=
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=b1gcrm
PGPASSWORD=
PGDATABASE=b1gcrm
PGSSL=false

# JWT & Authentication
# Generate strong values per device/deployment and never commit them.
JWT_SECRET=
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=

# Payment Gateway Keys
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email/SMTP Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# WhatsApp & Meta Integration
META_VERIFY_TOKEN=
META_WEBHOOK_TOKEN=
WHATSAPP_API_TOKEN=
META_APP_ID=
META_APP_SECRET=

# Redis Configuration (Optional - for caching/sessions)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# AWS S3 Configuration (for media storage)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=b1g-crm-media
AWS_REGION=us-east-1
S3_ENABLED=false

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3010
CORS_ORIGINS=http://localhost:5173,http://localhost:3010
API_BASE_URL=http://localhost:3010/api
STRIPE_LANG=en

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./client/public/media

# Twilio Configuration (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_WHATSAPP=true
ENABLE_INSTAGRAM=true
ENABLE_PAYMENTS=true
ENABLE_BROADCAST=true
ENABLE_CHATBOT=true
ENABLE_API_KEYS=true
